# =============================================================================
# Neon PostgreSQL — Clínica del Niño
# =============================================================================
#
# DATABASE_URL (pooler) → app en runtime (Next.js / Vercel)
#   - Host con sufijo "-pooler" en Neon
#   - Incluir pgbouncer=true para Prisma + connection pool
#
# DIRECT_URL (conexión directa) → prisma db push, migrate, seed
#   - Host SIN "-pooler"
#   - No usar para tráfico de la app en producción
#
# En Neon Console: Connection details → copiar "Pooled" y "Direct"
# =============================================================================

# Pooled (runtime — Next.js)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct (migraciones / prisma db push / seed)
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Local sin pooler: podés usar la misma URL en ambas variables temporalmente.

# Opcional: activar logs SQL en desarrollo (por defecto solo error/warn)
# PRISMA_LOG_QUERIES="true"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
