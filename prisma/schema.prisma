generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
}

enum InquiryStatus {
  NUEVA
  CONTACTADA
  EN_SEGUIMIENTO
  RESUELTA
  CANCELADA
}

enum SiteContentType {
  TEXT
  HTML
  JSON
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ClinicSettings {
  id               String   @id @default("default")
  clinicName       String   @default("Clínica del Niño")
  slogan           String   @default("Atención pediátrica 24 horas, los 365 días del año.")
  whatsappNumber   String   @default("")
  phone            String   @default("")
  email            String   @default("")
  instagramUrl     String?
  facebookUrl      String?
  address          String   @default("Corrientes Capital")
  mapsUrl          String?
  mapsEmbedUrl     String?
  heroTitle        String   @default("Clínica del Niño")
  heroSubtitle     String   @default("Atención pediátrica 24 horas, los 365 días del año.")
  heroDescription  String   @default("Guardia pediátrica, internación clínica y quirúrgica, vacunatorio, neonatología, terapia intensiva y servicios complementarios en Corrientes Capital.")
  heroImageUrl     String?
  logoUrl          String?
  openingHoursJson String   @default("{}")
  emergencyNotice  String   @default("Ante emergencias graves, concurrir inmediatamente o comunicarse con servicios de emergencia.")
  legalNotice      String   @default("La información publicada no reemplaza una evaluación médica profesional. Ante emergencias, concurrir al centro de salud más cercano o comunicarse con emergencias.")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Service {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String
  longDescription  String   @default("")
  icon             String   @default("stethoscope")
  imageUrl         String?
  category         String?
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([active, sortOrder])
}

model InsuranceProvider {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  notes     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

model InquiryRequest {
  id               String        @id @default(cuid())
  inquiryCode      String        @unique
  childName        String
  childAge         String
  guardianName     String
  guardianPhone    String
  serviceRequested String
  insuranceProvider String?
  reason           String
  message          String?
  status           InquiryStatus @default(NUEVA)
  whatsappMessage  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([inquiryCode])
  @@index([createdAt])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

model SiteContent {
  id        String          @id @default(cuid())
  section   String
  key       String
  label     String
  value     String          @db.Text
  type      SiteContentType @default(TEXT)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([section, key])
  @@index([section])
}

model ImageAsset {
  id        String   @id @default(cuid())
  url       String
  pathname  String
  filename  String
  folder    String   @default("general")
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  @@index([folder])
}

model VaccineContent {
  id                    String   @id @default("default")
  title                 String   @default("Vacunatorio pediátrico")
  description           String   @db.Text
  calendarVaccines      String   @db.Text
  injectablesInfo       String   @db.Text
  requirements          String   @db.Text
  schedules             String   @db.Text
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
